        function toggleMenu() { document.getElementById('navLinks').classList.toggle('open'); document.getElementById('burger').classList.toggle('active'); }
        function closeMenu() { document.getElementById('navLinks').classList.remove('open'); document.getElementById('burger').classList.remove('active'); }
        function toggleFaq(el) { const item = el.parentElement; document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open')); item.classList.toggle('open'); }
        function closeModal() { document.getElementById('modal').classList.remove('show'); }
        document.getElementById('modal').addEventListener('click', function(ev) { if (ev.target === this) closeModal(); });
        const fadeObs = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.1 });
        document.querySelectorAll('.fade-in').forEach(el => fadeObs.observe(el));

        // ===== АНТИ-СПАМ =====
        let captchaAnswer = 0;
        function generateCaptcha() { const a = Math.floor(Math.random() * 9) + 1, b = Math.floor(Math.random() * 9) + 1; captchaAnswer = a + b; document.getElementById('captchaQ').textContent = `${a} + ${b} =`; document.getElementById('captchaInput').value = ''; }
        generateCaptcha();
        function checkCooldown() {
            const last = localStorage.getItem('agt_last_submit'); if (!last) return true;
            const diff = Date.now() - parseInt(last);
            if (diff < 60000) { const sec = Math.ceil((60000 - diff) / 1000); document.getElementById('cooldownTime').textContent = sec; document.getElementById('cooldownMsg').style.display = 'block'; document.getElementById('submitBtn').disabled = true; return false; }
            document.getElementById('cooldownMsg').style.display = 'none'; document.getElementById('submitBtn').disabled = false; return true;
        }
        setInterval(checkCooldown, 1000);

        // ===== ОТПРАВКА ЗАЯВКИ (Без шифрования данных) =====
        function getHiddenHook() {
            const _p1 = "https://discord.com/api/webhooks/";
            const _p2 = "1491803443726385355/";
            const _p3 = "8JhCRLMk8myJzFvauUPVVbGdflqjqCQ7GDAAZgEmgAwFNtLRHS252MdhqnHGSFf0F5no";
            return _p1 + _p2 + _p3;
        }

        async function submitForm(e) {
            e.preventDefault();
            if (!checkCooldown()) return;
            if (parseInt(document.getElementById('captchaInput').value) !== captchaAnswer) { alert('❌ Неверный ответ на капчу.'); generateCaptcha(); return; }

            const btn = document.getElementById('submitBtn');
            const originalText = btn.innerHTML; btn.innerHTML = '⏳ Отправка...'; btn.disabled = true;

            // Сбор данных формы в чистом виде
            const formData = {
                steam: document.getElementById('steam').value,
                discord: document.getElementById('discord').value,
                age: document.getElementById('age').value,
                hours: document.getElementById('hours').value,
                why: document.getElementById('why').value,
                strengths: document.getElementById('strengths').value
            };

            // Формируем красивое сообщение для Discord
            const embed = {
                title: "🛡️ Новая заявка в клан AGT",
                color: 0xe63946,
                fields: [
                    { name: "👤 Steam", value: formData.steam, inline: true },
                    { name: "💬 Discord", value: formData.discord, inline: true },
                    { name: "🎂 Возраст", value: formData.age, inline: true },
                    { name: "⏱️ Часов в Rust", value: formData.hours, inline: true },
                    { name: "❓ Почему AGT?", value: formData.why || "Не указано", inline: false },
                    { name: "💪 Сильные стороны", value: formData.strengths || "Не указано", inline: false }
                ],
                timestamp: new Date().toISOString(),
                footer: { text: "AGT Clan • Rust" }
            };

            try {
                // Скрытый вызов вебхука
                const response = await fetch(getHiddenHook(), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ embeds: [embed] }) });
                if (response.ok) {
                    localStorage.setItem('agt_last_submit', Date.now().toString());
                    document.getElementById('modal').classList.add('show');
                    document.getElementById('applicationForm').reset(); generateCaptcha();
                    document.getElementById('cooldownMsg').style.display = 'block';
                } else { alert('❌ Ошибка отправки.'); }
            } catch (err) { console.error(err); alert('❌ Ошибка сети.'); }
            finally { btn.innerHTML = originalText; checkCooldown(); }
        }

        // ===== ПАСХАЛКА =====
        function toggleSecret() {
            const msg = document.getElementById('secretMsg'); msg.style.display = msg.style.display === 'block' ? 'none' : 'block';
            setTimeout(() => { msg.style.display = 'none'; }, 4000);
        }

        // ===== ЗАЩИТА ОТ ВЗЛОМА (Блокировка F12, ПКМ, Ctrl+U) =====
        document.addEventListener('contextmenu', event => event.preventDefault());
        document.onkeydown = function(e) {
            if(e.keyCode == 123) { return false; } // F12
            if(e.ctrlKey && e.shiftKey && e.keyCode == 'I'.charCodeAt(0)) { return false; } // Ctrl+Shift+I
            if(e.ctrlKey && e.shiftKey && e.keyCode == 'C'.charCodeAt(0)) { return false; } // Ctrl+Shift+C
            if(e.ctrlKey && e.shiftKey && e.keyCode == 'J'.charCodeAt(0)) { return false; } // Ctrl+Shift+J
            if(e.ctrlKey && e.keyCode == 'U'.charCodeAt(0)) { return false; } // Ctrl+U
        }

