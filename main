                if (d < _0x1[7].connDist) {
                    const o = (1 - d / _0x1[7].connDist) * 0.7;
                    _0x1[0].beginPath(); _0x1[0].moveTo(_0x2[i].x, _0x2[i].y); _0x1[0].lineTo(_0x2[j].x, _0x2[j].y);
                    _0x1[0].strokeStyle = `rgba(230,57,70,${o})`; _0x1[0].lineWidth = (1 - d / _0x1[7].connDist) * 2; _0x1[0].stroke();
